# ─── Server ──────────────────────────────────────────────────────────────────
# Port the relay API + WebSocket feed listen on
PORT=4000

# ─── Stellar ─────────────────────────────────────────────────────────────────
# Network to operate against: testnet | futurenet | mainnet
STELLAR_NETWORK=testnet
# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract IDs (leave blank until deployed)
SETTLEMENT_CONTRACT_ID=
SOLVER_REGISTRY_CONTRACT_ID=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend ("*" for any in dev)
CORS_ORIGIN=*
